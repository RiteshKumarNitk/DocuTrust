generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        String     @id @default(uuid())
  email     String     @unique
  password  String
  createdAt DateTime   @default(now())
}

model Document {
  id          String    @id @default(uuid())
  userId      String
  fileUrl     String
  type        String
  status      String    @default("PENDING")
  extracted   String?
  score       Int?
  result      String?
  errorMsg    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}
